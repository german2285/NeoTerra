{
  "schemaVersion": 1,
  "id": "neoterra",
  "version": "${version}",
  "name": "NeoTerra",
  "description": "Custom world generation for Minecraft: terrain, biomes, surface rules, structures, presets",
  "authors": [
    "dags",
    "Won-Ton"
  ],
  "contact": {
    "repo": "https://github.com/german2285/NeoTerra/",
    "issues": "https://github.com/german2285/NeoTerra/issues"
  },
  "license": "MIT",
  "environment": "*",
  "entrypoints": {
    "main": [
      "neoterra.fabric.NTFabric"
    ],
    "fabric-datagen": [
      "neoterra.fabric.NTFabric"
    ]
  },
  "depends": {
    "fabricloader": ">=0.14.14",
    "fabric": ">=0.86.1",
    "minecraft": ">=1.20.1"
  },
  "mixins": [
    "neoterra-common.mixins.json",
    "neoterra-fabric.mixins.json"
  ],
  "icon": "assets/neoterra/icon.png"
}